      "steps": [
        "copy ./alert-events-notifications-email.cf services/cfbs/alert-events-notifications-email.cf",
        "policy_files services/cfbs/alert-events-notifications-email.cf",
        "bundles alert_events_notifications_email"
      ]
    }
  ],
  "git": true
}
