{
  "name": "Example",
  "type": "policy-set",
  "description": "Play around with CFBS",
  "build": [
    {
      "name": "./masterfiles/",
      "description": "Local subdirectory added using cfbs command line",
      "tags": ["local"],
      "added_by": "cfbs add",
      "steps": ["run ./prepare.sh -y", "copy ./ ./"]
    },
    {
      "name": "autorun",
      "description": "Enable autorun functionality",
      "tags": ["supported", "management"],
      "repo": "https://github.com/cfengine/modules",
      "by": "https://github.com/olehermanse",
      "version": "1.0.1",
      "commit": "c3b7329b240cf7ad062a0a64ee8b607af2cb912a",
      "subdirectory": "management/autorun",
      "added_by": "compliance-report-imports",
      "steps": ["json def.json def.json"]
    },
    {
      "name": "demo",
      "version": "1.0.0",
      "description": "Enables convenient and insecure settings for demoing CFEngine",
      "tags": ["management", "experimental"],
      "repo": "https://github.com/cfengine/modules",
      "by": "https://github.com/olehermanse",
      "commit": "05bf5e5b1c014018a7b93a524e035c1a21bcffa4",
      "subdirectory": "management/demo",
      "dependencies": ["autorun", "every-minute"],
      "added_by": "cfbs add",
      "steps": ["json def.json def.json"]
    },
    {
      "name": "library-for-promise-types-in-python",
      "description": "Library enabling promise types implemented in python",
      "tags": ["supported", "library"],
      "repo": "https://github.com/cfengine/modules",
      "by": "https://github.com/cfengine",
      "version": "0.1.1",
      "commit": "c3b7329b240cf7ad062a0a64ee8b607af2cb912a",
      "subdirectory": "libraries/python/",
      "added_by": "promise-type-groups",
      "steps": ["copy cfengine.py modules/promises/"]
    },
    {
      "name": "promise-type-groups",
      "description": "Experimental promise type to manage local user groups",
      "tags": ["supported", "promise-type", "experimental"],
      "repo": "https://github.com/cfengine/modules",
      "by": "https://github.com/larsewi",
      "version": "0.1.3",
      "commit": "fd255fbdcc6cac0521ab8de2c543c684fadb16fa",
      "subdirectory": "promise-types/groups/",
      "dependencies": ["library-for-promise-types-in-python"],
      "added_by": "cfbs add",
      "steps": [
        "copy groups.py modules/promises/",
        "append enable.cf services/init.cf"
      ]
    },
    {
      "name": "upgrade-all-packages",
      "version": "0.0.2",
      "description": "This module ensures that the package manager data is updated and all upgradeable packages are upgraded",
      "tags": ["supported", "security", "compliance"],
      "repo": "https://github.com/craigcomstock/cfengine-security-hardening",
      "by": "https://github.com/craigcomstock",
      "commit": "2ec06ea5e78b0ad39cfde0137e0a8c25a983fae8",
      "subdirectory": "upgrade-all-packages",
      "dependencies": ["autorun"],
      "added_by": "cfbs add",
      "steps": [
        "copy ./upgrade_all_packages.cf services/autorun/upgrade_all_packages.cf"
      ]
    },
    {
      "name": "./manual-testing/inventory_from_classes_common_bundle.cf",
      "description": "Local policy file added using cfbs command line",
      "tags": ["local"],
      "added_by": "cfbs add",
      "steps": [
        "copy ./manual-testing/inventory_from_classes_common_bundle.cf services/cfbs/manual-testing/inventory_from_classes_common_bundle.cf",
        "policy_files services/cfbs/manual-testing/inventory_from_classes_common_bundle.cf"
      ]
    },
    {
      "name": "./manual-testing/release-test-extend-inventory-via-vars-classes-module.cf",
      "description": "Local policy file added using cfbs command line",
      "tags": ["local"],
      "added_by": "cfbs add",
      "steps": [
        "copy ./manual-testing/release-test-extend-inventory-via-vars-classes-module.cf services/cfbs/manual-testing/release-test-extend-inventory-via-vars-classes-module.cf",
        "policy_files services/cfbs/manual-testing/release-test-extend-inventory-via-vars-classes-module.cf",
        "bundles release_test_extend_inventory_via_vars_classes_module"
      ]
    },
    {
      "name": "./manual-testing/chrony.cf",
      "description": "Local policy file added using cfbs command line",
      "tags": ["local"],
      "added_by": "cfbs add",
      "steps": [
        "copy ./manual-testing/chrony.cf services/cfbs/manual-testing/chrony.cf",
        "policy_files services/cfbs/manual-testing/chrony.cf",
        "bundles chrony"
      ]
    },
    {
      "name": "./manual-testing/changes_test.cf",
      "description": "Local policy file added using cfbs command line",
      "tags": ["local"],
      "added_by": "cfbs add",
      "steps": [
        "copy ./manual-testing/changes_test.cf services/cfbs/manual-testing/changes_test.cf",
        "policy_files services/cfbs/manual-testing/changes_test.cf",
        "bundles changes_test"
      ]
    },
    {
      "name": "compliance-report-imports",
      "description": "Keep compliance report definitions up to date",
      "tags": ["experimental", "cfengine-enterprise"],
      "repo": "https://github.com/nickanderson/cfengine-security-hardening",
      "by": "https://github.com/nickanderson",
      "version": "0.0.8",
      "commit": "06f0894b662befbba4e775884f21cfe8573c32d6",
      "subdirectory": "./compliance-report-imports",
      "dependencies": ["autorun"],
      "added_by": "compliance-report-lynis",
      "steps": ["copy ./compliance-report-imports.cf services/autorun/"]
    },
    {
      "name": "lynis",
      "description": "CFEngine policy to automate the installation, running, and reporting of CISOfy's lynis system audits",
      "tags": ["security", "compliance", "experimental"],
      "repo": "https://github.com/nickanderson/cfengine-lynis",
      "by": "https://github.com/nickanderson",
      "version": "0.3.2",
      "commit": "da3dc477846d4885688aba93f4f0df38dd14bf53",
      "added_by": "compliance-report-lynis",
      "steps": [
        "copy policy/main.cf services/lynis/main.cf",
        "json cfbs/def.json def.json"
      ]
    },
    {
      "name": "compliance-report-lynis",
      "version": "0.0.2",
      "description": "Compliance report with Lynis checks",
      "tags": ["experimental", "security", "compliance"],
      "repo": "https://github.com/nickanderson/cfengine-lynis",
      "by": "https://github.com/nickanderson/",
      "commit": "60ad7321d6b5e30606830d3228812fe3f77c4fa8",
      "subdirectory": "./compliance-reports",
      "dependencies": ["compliance-report-imports", "lynis"],
      "added_by": "cfbs add",
      "steps": [
        "copy ./generated-compliance-report.json .no-distrib/compliance-report-definitions/lynis-compliance-report.json"
      ]
    },
    {
      "name": "compliance-report-os-is-vendor-supported",
      "version": "0.0.2",
      "description": "Compliance report definition for checking if the current OS version is supported by the vendor",
      "tags": ["experimental", "compliance-report", "cfengine-enterprise"],
      "repo": "https://github.com/nickanderson/cfengine-security-hardening",
      "by": "https://github.com/nickanderson",
      "commit": "d9e0aad225535b2b16ba2126e8302f8ffc5e7d38",
      "subdirectory": "./compliance-report-os-is-vendor-supported",
      "dependencies": ["compliance-report-imports"],
      "added_by": "cfbs add",
      "steps": [
        "copy ./os-is-vendor-supported.json .no-distrib/compliance-report-definitions/os-is-vendor-supported.json"
      ]
    },
    {
      "name": "client-initiated-reporting",
      "version": "0.1.1",
      "description": "Enable client initiated reporting and disable pull collection",
      "tags": ["experimental", "reporting"],
      "repo": "https://github.com/cfengine/modules",
      "by": "https://github.com/cfengine",
      "commit": "c3b7329b240cf7ad062a0a64ee8b607af2cb912a",
      "subdirectory": "reporting/client-initiated-reporting",
      "added_by": "cfbs add",
      "steps": ["json def.json def.json"]
    },
    {
      "name": "enable-aslr",
      "version": "0.0.2",
      "description": "Ensure that Address space layout randomization (ASLR) is enabled on the system",
      "tags": ["supported", "security", "compliance"],
      "repo": "https://github.com/cfengine/modules",
      "by": "https://github.com/craigcomstock",
      "commit": "5507dc81587ccb833c5092fd5baeb52dd1b3fdd3",
      "subdirectory": "security/enable-aslr",
      "added_by": "cfbs add",
      "steps": [
        "copy enable-aslr.cf services/cfbs/modules/enable-aslr/enable-aslr.cf",
        "bundles enable_aslr",
        "policy_files services/cfbs/modules/enable-aslr/enable-aslr.cf"
      ]
    },
    {
      "name": "uninstall-rsh-server",
      "version": "0.0.2",
      "description": "Ensure the remote shell (rsh) server package is not installed on the system",
      "tags": ["supported", "security", "compliance"],
      "repo": "https://github.com/cfengine/modules",
      "by": "https://github.com/olehermanse",
      "commit": "d7ab64b9874e39e64508dd169237563dc9ad8176",
      "subdirectory": "security/uninstall-rsh-server",
      "added_by": "cfbs add",
      "steps": [
        "copy uninstall-rsh-server.cf services/cfbs/modules/uninstall-rsh-server/uninstall-rsh-server.cf",
        "bundles uninstall_rsh_server",
        "policy_files services/cfbs/modules/uninstall-rsh-server/uninstall-rsh-server.cf"
      ]
    },
    {
      "name": "etc-motd-access",
      "version": "0.0.1",
      "description": "Limit access to /etc/motd by setting user, group, and permission bits.",
      "tags": ["supported", "security", "compliance"],
      "repo": "https://github.com/cfengine/modules",
      "by": "https://github.com/olehermanse",
      "commit": "2c54a98a05bb0315c7a5b9b2edf17a629f151563",
      "subdirectory": "security/etc-motd-access",
      "added_by": "cfbs add",
      "steps": [
        "copy etc-motd-access.cf services/cfbs/modules/etc-motd-access/etc-motd-access.cf",
        "bundles etc_motd_access",
        "policy_files services/cfbs/modules/etc-motd-access/etc-motd-access.cf"
      ]
    },
    {
      "name": "uninstall-talk",
      "version": "0.0.1",
      "description": "Ensure the talk client and server packages are not installed",
      "tags": ["supported", "security", "compliance"],
      "repo": "https://github.com/cfengine/modules",
      "by": "https://github.com/olehermanse",
      "commit": "36ff5729aeba97d72bdadfdb53bb4cc19c81f900",
      "subdirectory": "security/uninstall-talk",
      "added_by": "cfbs add",
      "steps": [
        "copy uninstall-talk.cf services/cfbs/modules/uninstall-talk/uninstall-talk.cf",
        "bundles uninstall_talk",
        "policy_files services/cfbs/modules/uninstall-talk/uninstall-talk.cf"
      ]
    },
    {
      "name": "delete-home-dotshosts",
      "version": "0.0.4",
      "description": "Ensure that ~/.shosts files are not present, as they present a security risk",
      "tags": ["supported", "security", "compliance"],
      "repo": "https://github.com/cfengine/modules",
      "by": "https://github.com/nickanderson",
      "commit": "8bb6e0703139ffc979159b7a2d2750f08b80b497",
      "subdirectory": "security/delete-home-dotshosts",
      "added_by": "cfbs add",
      "steps": [
        "copy policy/main.cf services/cfbs/delete-home-dotshots/",
        "policy_files services/cfbs/delete-home-dotshots/",
        "bundles delete_home_dotshosts:main"
      ]
    },
    {
      "name": "etc-issue-access",
      "version": "0.0.1",
      "description": "Limit access to /etc/issue by setting user, group, and permission bits.",
      "tags": ["supported", "security", "compliance"],
      "repo": "https://github.com/cfengine/modules",
      "by": "https://github.com/olehermanse",
      "commit": "36ff5729aeba97d72bdadfdb53bb4cc19c81f900",
      "subdirectory": "security/etc-issue-access",
      "added_by": "cfbs add",
      "steps": [
        "copy etc-issue-access.cf services/cfbs/modules/etc-issue-access/etc-issue-access.cf",
        "bundles etc_issue_access",
        "policy_files services/cfbs/modules/etc-issue-access/etc-issue-access.cf"
      ]
    },
    {
      "name": "library-parsed-local-users",
      "description": "Parse local users from /etc/passwd on the system with their attributes from /etc/shadow",
      "tags": ["supported", "library"],
      "repo": "https://github.com/nickanderson/cfengine-local_users",
      "by": "https://github.com/nickanderson",
      "version": "2.0.5",
      "commit": "ede282c34083ab807543aa734b1142228ab98993",
      "subdirectory": "parsed_etc_passwd_shadow/",
      "added_by": "inventory-local-users-unhashed-password",
      "steps": [
        "copy ./parsed_etc_passwd_shadow.cf services/local-users/parsed_etc_passwd_shadow/",
        "json cfbs/def.json def.json"
      ]
    },
    {
      "name": "inventory-local-users-unhashed-password",
      "version": "1.0.0",
      "description": "Adds reporting data (inventory) for local users not using hashed passwords.",
      "tags": ["supported", "inventory", "security", "compliance"],
      "repo": "https://github.com/cfengine/modules",
      "by": "https://github.com/nickanderson",
      "commit": "057f24c8e96ef5504779d45f3f8a19907ccf0b32",
      "subdirectory": "security/inventory-local-users-unhashed-password/",
      "dependencies": ["library-parsed-local-users"],
      "added_by": "cfbs add",
      "steps": [
        "copy policy/main.cf services/cfbs/inventory-local-users-unhashed-password/",
        "policy_files services/cfbs/inventory-local-users-unhashed-password/",
        "bundles inventory_local_users_unhashed_password:main"
      ]
    }
  ],
  "git": true
}
